@using Shubhdecoration.Data.Account
@model DashboardModel;
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link href="~/css/dashboard.css" rel="stylesheet" />
<div>
    <main class="main-content">
        <header class="top-header">
            <button class="toggle-sidebar-btn" onclick="toggleSidebar()">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
            <div class="user-profile-section">
                <span class="welcome-text">Welcome, <strong>Admin</strong></span>
                <div class="avatar">A</div>
            </div>
        </header>
        <div class="dashboard-body">
            <div class="metrics-grid">
                <div class="card gradient-card-1">
                    <div class="card-info">
                        <h3>Total Bookings</h3>
                        <p class="card-value">148</p>
                    </div>
                    <div class="card-icon-wrapper">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </div>
                </div>
                <div class="card gradient-card-2">
                    <div class="card-info">
                        <h3>Active Events</h3>
                        <p class="card-value">12</p>
                    </div>
                    <div class="card-icon-wrapper">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 22 22 22"></polygon></svg>
                    </div>
                </div>
                <div class="card gradient-card-3">
                    <div class="card-info">
                        <h3>Total Categories</h3>
                        <p class="card-value">5</p>
                    </div>
                    <div class="card-icon-wrapper">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
                    </div>
                </div>
            </div>
            <div class="table-container">
                <div class="table-header">
                    <h2>Recent Event Enquiries</h2>
                </div>
                <div class="responsive-table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>User Name</th> 
                                <th>Mobile No</th>
                                <th>Email</th>
                                @* <th>Uset Type</th> *@
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Model.UserList != null && Model.UserList.Count > 0)
                            {
                                foreach(var user in Model.UserList)
                                {
                                    <tr>
                                        <td>@(user.FName+" "+user.LName)</td> 
                                        <td>@user.MobileNo</td>  
                                        <td>@user.EmailId</td>  
                                        @* <td>@user.UserRole</td>   *@
                                        <td></td>  
                                        <td> 
                                            @if(user.IsActive)
                                            {
                                                <span class="status-badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge badge-pending">In-Active</span>
                                            }
                                        </td>  
                                    </tr>
                                }
                            }

                           @*  <tr>
                                <td>Rahul Sharma</td>
                                <td>Wedding & Reception</td>
                                <td>+91 9876543210</td>
                                <td>28-Jun-2026</td>
                                <td><span class="status-badge badge-success">Confirmed</span></td>
                            </tr>
                            <tr>
                                <td>Priya Patel</td>
                                <td>Pre-Wedding Events</td>
                                <td>+91 9123456789</td>
                                <td>05-Jul-2026</td>
                                <td><span class="status-badge badge-pending">Pending</span></td>
                            </tr>
                            <tr>
                                <td>Amit Verma</td>
                                <td>Birthdays & Parties</td>
                                <td>+91 9988776655</td>
                                <td>12-Jul-2026</td>
                                <td><span class="status-badge badge-success">Confirmed</span></td>
                            </tr>
                            <tr>
                                <td>Suresh Kumar</td>
                                <td>Corporate Events</td>
                                <td>+91 8877665544</td>
                                <td>20-Aug-2026</td>
                                <td><span class="status-badge badge-cancelled">Cancelled</span></td>
                            </tr> *@
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>