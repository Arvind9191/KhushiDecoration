@model Shubhdecoration.Data.Account.SignupModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration Form</title>
    <link rel="stylesheet" href="~/css/auth-style.css" asp-append-version="true" />
    <style>
            *{
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            }

            body {
                background: linear-gradient(135deg, #1263d7 0%, #0cd6a2 100%);
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 20px;
            }

            .page-container {
                width: 100%;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            .form-card {
                background: #ffffff;
                width: 100%;
                max-width: 480px;
                padding: 40px 35px;
                border-radius: 4px;
                position: relative;
                box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.15);
            }

            .close-btn {
                position: absolute;
                top: 15px;
                right: 20px;
                background: none;
                border: none;
                font-size: 28px;
                line-height: 1;
                color: #4ee1be;
                cursor: pointer;
                transition: color 0.2s;
            }

                .close-btn:hover {
                    color: #1263d7;
                }

            .form-title {
                text-align: center;
                color: #1a73e8;
                font-size: 1.5rem;
                font-weight: 600;
                margin-bottom: 35px;
                letter-spacing: 0.5px;
            }

                .form-title .dot {
                    color: #1a73e8;
                    font-size: 1.2rem;
                    vertical-align: middle;
                }
                 
            .input-group {
                position: relative;
                margin-bottom: 25px;
            }

                .input-group input {
                    width: 100%;
                    padding: 10px 0px 6px 0px;
                    border: none;
                    border-bottom: 2px solid #a3f1dc;
                    font-size: 0.95rem;
                    color: #333;
                    outline: none;
                    background: transparent;
                    transition: border-color 0.3s;
                }
                 
                .input-group label {
                    position: absolute;
                    top: 10px;
                    left: 0;
                    font-size: 0.95rem;
                    color: #888;
                    pointer-events: none;
                    transition: all 0.3s ease;
                }

                .input-group .required {
                    color: #333;
                    margin-right: 4px;
                }
                 
                .input-group input:focus ~ label,
                .input-group input:not(:placeholder-shown) ~ label {
                    top: -14px;
                    font-size: 0.75rem;
                    color: #0cd6a2;
                }

                .input-group input:focus {
                    border-bottom-color: #0cd6a2;
                }
                 
            .password-group {
                position: relative;
            }

            .password-toggle {
                position: absolute;
                right: 5px;
                top: 12px;
                color: #1263d7;
                cursor: pointer;
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.5px;
                user-select: none;
            }

            .checkbox-group {
                display: flex;
                align-items: flex-start;
                gap: 10px;
                margin-top: 25px;
                margin-bottom: 30px;
            }

                .checkbox-group input[type="checkbox"] {
                    margin-top: 2px;
                    accent-color: #1263d7;
                    cursor: pointer;
                    width: 14px;
                    height: 14px;
                }

                .checkbox-group label {
                    font-size: 0.68rem;
                    color: #999;
                    line-height: 1.4;
                    text-align: left;
                    cursor: pointer;
                    user-select: none;
                }
                 
            .btn-submit {
                width: 100%;
                padding: 14px;
                background: linear-gradient(to right, #0099ff 0%, #00cc99 100%);
                border: none;
                border-radius: 4px;
                color: white;
                font-size: 0.95rem;
                font-weight: 500;
                letter-spacing: 1px;
                cursor: pointer;
                transition: opacity 0.3s;
            }

                .btn-submit:hover {
                    opacity: 0.9;
                }

            /* Card Footer Links */
            .form-footer {
                text-align: center;
                margin-top: 20px;
                font-size: 0.8rem;
                color: #666;
            }

                .form-footer a {
                    color: #1263d7;
                    text-decoration: none;
                    font-weight: 500;
                }

                    .form-footer a:hover {
                        text-decoration: underline;
                    }
                     
            @@media (max-width: 480px) {
                body {
                    padding: 10px;
                } 
                .form-card {
                    padding: 30px 20px;
                }

                .form-title {
                    font-size: 1.3rem;
                    margin-bottom: 25px;
                }
            }

            .text-danger {
                color: #e74c3c;
                font-size: 0.72rem;
                position: absolute;
                bottom: -18px;
                left: 0;
            } 
            .text-danger-summary {
                color: #e74c3c;
                font-size: 0.85rem;
                margin-bottom: 15px;
                text-align: center;
                list-style: none;
            } 
            .password-group {
                margin-bottom: 30px;
            }
    </style>
</head>
<body> 
    <div class="page-container">
        <div class="form-card">
            <button class="close-btn" type="button" onclick="window.history.back();">&times;</button>
            <h2 class="form-title">
                <span class="dot">•</span> Registration Form <span class="dot">•</span>
            </h2>  
            <form asp-action="Signup" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger-summary"></div>
                <div class="input-group">
                    <input asp-for="Name" required placeholder=" " autocomplete="off" />
                    <label asp-for="Name"><span class="required">*</span> Name</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <input asp-for="Email" required placeholder=" " autocomplete="off" />
                    <label asp-for="Email"><span class="required">*</span> Email address</label>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <input asp-for="Phone" required placeholder=" " autocomplete="off" />
                    <label asp-for="Phone"><span class="required">*</span> Phone</label>
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="input-group password-group">
                    <input asp-for="Password" required placeholder=" " autocomplete="off" type="password" id="RegPassword" />
                    <label asp-for="Password"><span class="required">*</span> Password</label>
                    <span class="password-toggle" onclick="togglePassword('RegPassword', 'toggleTextPass')" id="toggleTextPass">SHOW</span>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="input-group password-group">
                    <input asp-for="ConfirmPassword" required placeholder=" " autocomplete="off" type="password" id="ConfirmPassword" />
                    <label asp-for="ConfirmPassword"><span class="required">*</span> Confirm Password</label>
                    <span class="password-toggle" onclick="togglePassword('ConfirmPassword', 'toggleTextConf')" id="toggleTextConf">SHOW</span>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div> 
                <div class="checkbox-group">
                    <input asp-for="TermsAccepted" required />
                    <label asp-for="TermsAccepted">
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat
                    </label>
                    <span asp-validation-for="TermsAccepted" class="text-danger" style="display:block; margin-top:5px;"></span>
                </div>
                <button type="submit" class="btn-submit">CREATE ACCOUNT</button>
            </form>
        </div>        
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>  
            function togglePassword(inputId, toggleId) {
                const passwordInput = document.getElementById(inputId);
                const toggleText = document.getElementById(toggleId);
    
                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    toggleText.innerText = "HIDE";
                } else {
                    passwordInput.type = "password";
                    toggleText.innerText = "SHOW";
                }
            }
    </script>
</body>
</html>