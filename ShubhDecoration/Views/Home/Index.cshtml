 

<style>
    
    .decor-card {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.10);
        transition: all .4s ease;
        height: 100%;
        position: relative;
    }
        .decor-card:hover {
            transform: translateY(-8px) scale(1.03);
            box-shadow: 0 18px 35px rgba(0,0,0,.20);
        }
    .decor-image-wrapper {
        position: relative;
        overflow: hidden;
    }
    .decor-image {
        width: 100%;
        height: 320px;
        object-fit: cover;
        transition: transform .5s ease;
    }
    .decor-card:hover .decor-image {
        transform: scale(1.08);
    }
    .wishlist-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: none;
        background: rgba(255,255,255,.9);
        font-size: 20px;
        cursor: pointer;
        z-index: 10;
    }
        .wishlist-btn:hover {
            background: #fff;
        }
    .decor-content {
        padding: 18px;
    }
    .decor-title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 10px;
        color: #222;
    }
    .decor-location {
        color: #777;
        margin-bottom: 10px;
        font-size: 15px;
    }
    .decor-footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }
    .rating {
        color: #FFC107;
        font-size: 18px;
        margin-bottom: 10px;
    }
    .price {
        font-size: 24px;
        font-weight: 700;
        color: #111;
    }
    .book-btn {
        background: #6f2dbd;
        color: #fff;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 6px;
        display: inline-block;
        font-size: 14px;
        font-weight: 600;
        transition: .3s;
    }
        .book-btn:hover {
            background: #5a189a;
            color: #fff;
        }

    @@media(max-width:992px) {
        .decor-image {
            height: 280px;
        }

        .decor-title {
            font-size: 20px;
        }
    }

    @@media(max-width:576px) {
        .decor-image {
            height: 250px;
        }

        .decor-title {
            font-size: 18px;
        }

        .price {
            font-size: 20px;
        }

        .book-btn {
            padding: 8px 14px;
            font-size: 13px;
        }
    }
</style>


