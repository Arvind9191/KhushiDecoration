@using Shubhdecoration.Data.Common
@model ResponseModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notification</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        } 
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #f5f6f9;
        } 
        .page-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: rgba(0, 0, 0, 0.4); /* Page background dark transparent popup look */
            padding: 15px;
        } 
        .form-card {
            background-color: #ffffff;
            width: 100%;
            max-width: 480px;
            border-radius: 16px;
            padding: 32px;
            text-align: center;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            position: relative;
            animation: swalScaleIn 0.3s ease-out;
        } 
        @@keyframes swalScaleIn {
            0% { transform: scale(0.7); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        } 
        .close-btn {
            position: absolute;
            top: 15px;
            right: 20px;
            background: none;
            border: none;
            font-size: 24px;
            color: #bcc2cb;
            cursor: pointer;
            transition: color 0.2s;
        }

        .close-btn:hover {
            color: #6c757d;
        } 
        .swal-icon-placeholder {
            width: 80px;
            height: 80px;
            border: 4px solid #a5dc86; /* Default Green for Success style */
            border-radius: 50%;
            margin: 0 auto 20px auto;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #a5dc86;
            font-size: 40px;
            font-weight: bold;
        } 
        .form-title-main {
            font-size: 26px;
            font-weight: 600;
            color: #545454;
            margin-bottom: 12px;
            line-height: 1.2;
        } 
        .form-message-desc {
            font-size: 16px;
            font-weight: 400;
            color: #545454;
            line-height: 1.5;
            margin-bottom: 25px;
            word-wrap: break-word;
        } 
        .swal-confirm-btn {
            background-color: #7066e0;  
            color: #ffffff;
            border: none;
            border-radius: 5px;
            padding: 12px 32px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            box-shadow: 0 0 0 3px transparent;
            transition: background-color 0.2s;
        } 
        .swal-confirm-btn:hover {
            background-color: #5b51cc;
        } 
        .swal-confirm-btn:focus {
            box-shadow: 0 0 0 3px rgba(112, 102, 224, 0.5);
            outline: none;
        }
    </style>
</head>
<body> 
    <div class="page-container">
        <div class="form-card">
            <button class="close-btn" type="button" onclick="window.history.back();">&times;</button> 
            @if(Model!=null &&  Model.IsSuccess)
            {
                <div class="swal-icon-placeholder">✓</div>
                 <h2 class="form-title-main">
                @Model.Title
            </h2> 
            <p class="form-message-desc text-su">
            @if(Model.InfoType==1)
                    { 
                @Model.Message <a class="" href="/Account/Login">Login</a>
           
                    }
                    else
                    {
                        @Model.Message  
                    }
                   </p> 
            }  
             
            <button class="swal-confirm-btn" type="button" onclick="window.history.back();">
                OK
            </button>
        </div>
    </div> 
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    } 
    <script>
        function togglePassword(inputId, toggleId) {
            const passwordInput = document.getElementById(inputId);
            const toggleText = document.getElementById(toggleId); 
            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                toggleText.innerText = "HIDE";
            } else {
                passwordInput.type = "password";
                toggleText.innerText = "SHOW";
            }
        }
    </script>
</body>
</html>