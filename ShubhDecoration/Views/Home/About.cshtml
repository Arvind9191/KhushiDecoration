@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor Accessor
@using Newtonsoft.Json;
@{
    string Role = Accessor.HttpContext.Session.GetString("UserRole") ?? "";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}
<link href="~/css/homestyle.css" rel="stylesheet" /> 
<section class="breadcrumb-section mt-3">
    <div class="container">
        <a href="/">Home</a>
        <span>></span>
        <span class="active">Vision Mission</span>
    </div>
</section>
<div class="">
    <div class="text-center">
        <h2 class="team-heading">About Khushi Decoration</h2>
        <p class="team-subtitle">Bringing Your Dream Celebrations to Life</p>
        <p>
            Welcome to Khushi Decoration, where we turn your special milestones into breathtaking, lifelong memories. True to our name—Khushi, meaning happiness—our mission is simple: to paint your most cherished days with vibrant colors, elegant floral designs, and absolute joy.
            Whether it is a grand traditional wedding, a lively Barat procession, an intimate birthday bash, or a corporate gathering, we blend creativity, precision, and passion to build spaces that speak to your heart.
        </p>
    </div>
    <div class="text-center">
        <h2 class="team-heading">Our Story</h2>
        <p>
            Every great celebration begins with a spark of an idea. Founded with a deep love for art, culture, and event styling, Khushi Decoration started as a small team with a big dream: to redefine how celebrations look and feel.
            Over the years, we have grown into a premier decoration service trusted by hundreds of families. We don’t just set up backdrops; we curate immersive environments. From majestic floral entrances to intricately adorned wedding cars, we treat every single detail as a piece of art.
        </p>
    </div>
</div>


<section class="about-section">
