<!-- ================= SECTION : HERO PROMO BANNER AND CARDS ================= -->
@if (Model != null && Model.decorations != null && Model.decorations.Any())
{
    for (int i = 0; i < Model.decorations.Count(); i++)
    {
        <section class="hero-banner responsive-banner" style="--bg-image: url('@Model.decorations[i].ImageUrl');">
            <div class="banner-content">
                <span class="banner-badge">@Model.decorations[i].CategoryName</span>
                <p>@(string.IsNullOrEmpty(Model.decorations[i].Description) ? "Explore our exclusive setups." : Model.decorations[i].Description)</p>
                <div class="banner-actions">
                    <a href="#shop" class="btn btn-primary">Explore Collection</a>
                </div>
            </div>
        </section>
        <div class="row col">
            <div class="col-12">
                <div class="card mt-3 mb-2">
                    <div class="card-header text-center">
                        <h6 class="banner-section-title">@Model.decorations[i].CategoryName</h6>
                    </div>
                    <div class="card-body">
                        <div class="container-fluid col-12 mt-3 mb-5">
                            <div class="row g-4">
                                @if (Model.decorations[i].CardList != null && Model.decorations[i].CardList.Any())
                                {
                                    for (int j = 0; j < Model.decorations[i].CardList.Count(); j++)
                                    {
                                        var card = Model.decorations[i].CardList[j];
                                        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 col-12">
                                            <div class="decor-card">
                                                <div class="decor-image-wrapper">
                                                    <img src="@card.ImageUrl" class="decor-image" alt="@card.Title">
                                                    <button class="wishlist-btn">♡</button>
                                                </div> 
                                                <div class="decor-content">
                                                    <span class="decor-title">@card.Title</span>
                                                    <p class="decor-location">@card.DecoName</p>
                                                    <div class="decor-footer-stacked">
                                                        <div class="decor-meta-row">
                                                            <div class="rating">★★★★★</div>
                                                            <div class="price">₹@card.Price.ToString("N0")</div>
                                                        </div>
                                                        <div class="action-buttons-group">
                                                            <a href="#" class="book-btn">BOOK NOW</a>
                                                            <a asp-controller="Decoration"
                                                                   asp-action="DecorationDetails"
                                                                   asp-route-cId="@Model.decorations[i].CategoryId"
                                                                   asp-route-dcId="@card.DecoTypeId"
                                                                   class="detail-btn">
                                                                DETAILS
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="col-12 text-center text-muted">
                                        <p>No items found under this category.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="card-footer text-center">
                        <a asp-controller="Decoration"
                               asp-action="DecorationDetails"
                               asp-route-cId="@Model.decorations[i].CategoryId" 
                               class="detail-btn">
                            Show All The kids Birthday Decodar
                        </a> 
                    </div>
                </div>
            </div>
        </div>
    }
}
