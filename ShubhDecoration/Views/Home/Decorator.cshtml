<link href="~/css/homestyle.css" rel="stylesheet" />
<div class="row col">
    <div class="col-12">
        <div id="heroSlider" class="carousel slide custom-carousel" data-bs-ride="carousel" data-bs-interval="4000">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroSlider" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#heroSlider" data-bs-slide-to="1" aria-label="Slide 2"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="slide-content-wrapper" style="background-image: url(https://cheetah.cherishx.com/website_layout/1680x400_Banner_Premium-Decorations_Desktop_20241116_122654.jpg?format=avif);">
                        <div class="slide-text-side">
                            <span class="badge bg-danger mb-2">Live Offers</span>
                            <h1 class="display-5 fw-bold">Premium Event Design</h1>
                            <p class="lead">Book premium, affordable birthday and anniversary setups directly in your neighborhood layout.</p>
                            <a href="#" class="btn btn-danger mt-2 px-4 py-2 fw-semibold">Book Now</a>
                        </div> 
                    </div>
                </div>
                <div class="carousel-item"> 
                        <div class="slide-content-wrapper" style="background-image: url(https://cheetah.cherishx.com/website_layout/1762405853__original_layout_55.jpg?format=avif);">
                        <div class="slide-text-side">
                            <span class="badge bg-warning text-dark mb-2">Trending</span>
                            <h1 class="display-5 fw-bold">Grand Balloon Backdrops</h1>
                            <p class="lead">Hand-crafted custom setups utilizing premium chrome and pastel combinations for any corporate event.</p>
                            <a href="#" class="btn btn-warning mt-2 px-4 py-2 fw-semibold">Explore Themes</a>
                        </div> 
                    </div>
                </div> 
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroSlider" data-bs-slide="prev">
                <span class="control-icon-btn" aria-hidden="true">
                    <i class="bi bi-chevron-left text-white fs-4"></i>
                </span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroSlider" data-bs-slide="next">
                <span class="control-icon-btn" aria-hidden="true">
                    <i class="bi bi-chevron-right text-white fs-4"></i>
                </span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
</div>


