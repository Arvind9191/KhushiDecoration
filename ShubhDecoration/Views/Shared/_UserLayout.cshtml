@using Microsoft.AspNetCore.Http
@using ShubhDecoration.Helper
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor Accessor
@using Newtonsoft.Json;
@{
    string UserName = Accessor.HttpContext.Session.GetString("UserName") ?? "Profile";
    if (string.IsNullOrEmpty(UserName))
    {
        UserName = "Profile";
    }
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Khushi Decoration</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="~/css/style.css" rel="stylesheet" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="~/css/userlayout.css" rel="stylesheet" />
</head>
<body>
    <header class="header header-menu">
        <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand  href-link" asp-controller="Decoration" asp-action="AllDecoration">
                    <img src="~/images/decologo.png"
                         alt="Logo"
                         class="img-fluid"
                         style="max-height:60px; border-radius:60px;">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNavDropdown">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle href-link" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Birthdays
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownMenuLink">
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.KidSBirthday">Kid`S Birthday</a></li>
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.YoungBirthday">Young Birthday</a></li>
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.Aniversary">Aniversary</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle  href-link" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Festivals
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownMenuLink">
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.DepawaliCelibration">Depawali Celibration</a></li>
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.Naveratri">Naveratri</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle href-link" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Events
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdownMenuLink">
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.Wedding">Wedding</a></li>
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.PreWedding">Pre-Wedding</a></li>
                                <li><a class="dropdown-item href-link" href="/Decoration/MoreDetails?cId=@DecorationEnum.WeddingProcession">Wedding Procession</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 d-flex align-items-lg-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link  href-link" href="/Account/Enquiry">Enquiry</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle fs-5 me-1"></i>@UserName
                            </a>
                            @if ((Accessor.HttpContext.Session.GetString("UserName") ?? "Profile") != "Profile")
                            {
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                                    <li><a class="dropdown-item href-link" href="#">Dashboard</a></li>
                                    <li><a class="dropdown-item href-link" href="#">Settings</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="/Account/Logout">Logout</a></li>
                                </ul>
                            }
                        </li>
                        @if ((Accessor.HttpContext.Session.GetString("UserName") ?? "Profile") == "Profile")
                        {
                            <li class="nav-item">
                                <a class="btn  bg-primary btn-sm w-100 w-lg-auto text-white" href="/Account/Signup">SignUp</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn  bg-primary btn-sm w-100 w-lg-auto text-white" href="/Account/Login">SignIn</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid">
        @RenderBody()
    </div>
    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-column brand-column">
                <div class="footer-logo">
                    <span class="logo-herb">Khushi</span><span class="logo-egy"> Decoration</span><span class="logo-tm">™</span>
                    <p class="logo-subtext mt-3">Think your decorate function</p>
                </div>
                <p class="footer-description">
                    Your True Partner of Events & Decorations Life. Think Pure Think Events With Us. <a href="#">More..</a>
                </p>
                <div class="social-icons">
                    <a href="#" class="social-icon" aria-label="Twitter">
                        <svg viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" /></svg>
                    </a>
                    <a href="#" class="social-icon" aria-label="Facebook">
                        <svg viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z" /></svg>
                    </a>
                    <a href="#" class="social-icon" aria-label="YouTube">
                        <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
                    </a>
                    <a href="#" class="social-icon" aria-label="LinkedIn">
                        <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
                    </a>
                    <a href="#" class="social-icon" aria-label="Instagram">
                        <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" /></svg>
                    </a>
                </div>
            </div>
            <div class="footer-column">
                <h3 class="column-title">Address</h3>
                <ul class="contact-list">
                    <li>
                        <svg class="contact-icon" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                        <span>Sarasawan,Sarasawan Manjhanpur KaushambiUttar Pradesh 212207</span>
                    </li>
                    <li>
                        <svg class="contact-icon" viewBox="0 0 24 24"><path fill="currentColor" d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" /></svg>
                        <span>
                            +91-9918284882<br />
                            +91-9170528251<br />
                            +91-9129743791
                        </span>
                    </li>
                    <li>
                        <svg class="contact-icon" viewBox="0 0 24 24"><path fill="currentColor" d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" /></svg>
                        <span>khushievents@gmail.com</span>
                    </li>
                </ul>
            </div>
            <div class="footer-column">
                <h3 class="column-title">Quick Links</h3>
                <ul class="links-list">
                    <li> <a href="/Home/About">About US</a></li>
                    <li><a href="/Home/Contact">Contact US</a></li>
                    <li><a href="#">Services</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h3 class="column-title">Newsletter</h3>
                <p class="newsletter-text">You may unsubscribe at any moment.</p>
                <form class="newsletter-form" onsubmit="event.preventDefault();">
                    <input type="email" placeholder="Your email" required class="newsletter-input" />
                    <button type="submit" class="newsletter-btn">SignUp</button>
                </form>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="bottom-container">
                <p class="copyright">© <span class="highlight"></span>, All Right Reserved.</p>
                <p class="credits">
                    Design By <span class="highlight-alt">AfiaInfotech</span><br />
                    Hosted By: <span class="highlight-alt">Shubh Decoration</span>
                </p>
            </div>
        </div>
        <button class="scroll-top-btn" onclick="window.scrollTo({top: 0, behavior: 'smooth'});" aria-label="Scroll to top">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" /></svg>
        </button>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>