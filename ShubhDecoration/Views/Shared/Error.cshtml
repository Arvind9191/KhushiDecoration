@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = null;
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShubhDecoration</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ShubhDecoration.styles.css" asp-append-version="true" />
</head>
<body>
<div class="text-center mt-5">
    <h1 class="text-danger">Oops! Something went wrong.</h1>
    <h4 class="text-muted">An error occurred while processing your request.</h4>
    <p>Our technical team has been notified.</p>

    @if (Model.ShowRequestId)
    {
        <p class="badge bg-secondary p-2">
            <strong>Tracking ID:</strong> <code class="text-white">@Model.RequestId</code>
        </p>
    }
    <div class="mt-4">
        <a href="/" class="btn btn-primary">Go to Home Page</a>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>