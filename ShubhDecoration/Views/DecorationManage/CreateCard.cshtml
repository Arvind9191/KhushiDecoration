@using Shubhdecoration.Data.Decoration
@model CreateCardModel;
@{
    ViewData["Title"] = "CreateCard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
} 
<div class="card">
    <div class="card-header">
        <h5>Add New Decoration</h5>
    </div>
    <div class="card-body">
        <div class="form-card-premium">
            <form asp-controller="DecorationManage" asp-action="CreateCard" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="form-grid-2col">
                    <div class="input-group-custom">
                        <input asp-for="Title" type="text" required placeholder=" " autocomplete="off" />
                        <label asp-for="Title"><span class="asterisk">*</span> Title / Deco Type</label>
                        <span asp-validation-for="Title" class="text-danger-msg"></span>
                    </div>

                    <div class="input-group-custom select-wrapper-custom">
                        <select asp-for="CategoryId" asp-items="@ViewBag.DdlCategory as SelectList" required>
                            <option value="" disabled selected hidden></option>
                        </select>
                        <label asp-for="CategoryId"><span class="asterisk">*</span> Select Category</label>
                        <span asp-validation-for="CategoryId" class="text-danger-msg"></span>
                    </div>
                </div>

                <div class="input-group-custom">
                    <input asp-for="DecoName" required placeholder=" " autocomplete="off" />
                    <label asp-for="DecoName"><span class="asterisk">*</span> Decoration Name</label>
                    <span asp-validation-for="DecoName" class="text-danger-msg"></span>
                </div>

                <div class="form-grid-2col">
                    <div class="input-group-custom">
                        <input asp-for="Price" type="number" step="0.01" required placeholder=" " autocomplete="off" />
                        <label asp-for="Price"><span class="asterisk">*</span> Price (₹)</label>
                        <span asp-validation-for="Price" class="text-danger-msg"></span>
                    </div>

                    <div class="input-group-custom file-wrapper-custom">
                        <input type="file" asp-for="Image" required placeholder=" " />
                        <label asp-for="Image"><span class="asterisk">*</span> Upload Decoration Image</label>
                        <span asp-validation-for="Image" class="text-danger-msg"></span>
                    </div>
                </div>

                <div class="input-group-custom">
                    <textarea asp-for="Description" rows="3" placeholder=" "></textarea>
                    <label asp-for="Description">Description / Package Inclusions</label>
                    <span asp-validation-for="Description" class="text-danger-msg"></span>
                </div>

                <div class="switch-container-row">
                    <label class="switch-label-text">Set Item Status Active</label>
                    <label class="custom-switch">
                        <input type="checkbox" asp-for="IsActive" checked />
                        <span class="switch-slider"></span>
                    </label>
                </div>

                <div class="form-actions-area">
                    <a href="/DecorationManage/DecoratiocardList" class="btn-cancel">Back to List</a>
                    <button type="submit" class="btn-submit-premium">Save Decoration</button>
                </div>
            </form>
             
        </div>
        <div class="insert-form-container">
           
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}



 
